{
  "name": "versecast",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source Bible-verse presenter for OBS — show scripture in multiple translations (KJV, Ang Dating Biblia 1905, extensible) with up to 4 split panes.",
  "type": "module",
  "main": "electron/main.mjs",
  "author": "Kenneth Jaramilla",
  "repository": {
    "type": "git",
    "url": "https://github.com/kennjaramilla/versecast.git"
  },
  "scripts": {
    "data": "node scripts/normalize.mjs",
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.mjs",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server/index.mjs",
    "app": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "io.github.kennjaramilla.versecast",
    "productName": "VerseCast",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**",
      "server/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "client/dist",
        "to": "client/dist"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.dmg",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "build/icon.png",
      "artifactName": "${productName}-Setup-${version}.exe",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kennjaramilla",
        "repo": "versecast",
        "releaseType": "release"
      }
    ]
  }
}
